generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Task:        Draft --approve--> Open --close--> Closed --reopen--> Open
enum TaskStatus {
  DRAFT
  OPEN
  CLOSED
}

// Application: Applied --assign--> Assigned (admin, up to max_assignees)
//                 |    --decline--> Declined (not selected; may re-apply)
//                 |    --withdraw--> Withdrawn
//              Assigned --unassign--> Applied (admin, records a reason)
//              Assigned --work approved--> Completed (terminal; slot stays consumed)
//              Assigned --work rejected--> Rejected (terminal; slot freed)
enum ApplicationStatus {
  APPLIED
  ASSIGNED
  DECLINED
  WITHDRAWN
  COMPLETED
  REJECTED
}

// Submission:  Submitted --approve--> Approved
//                        --reject---> Rejected (terminal - also closes the assignment)
//                        --revise---> Needs revision -> contributor submits a new version
enum SubmissionStatus {
  SUBMITTED
  APPROVED
  REJECTED
  NEEDS_REVISION
}

enum SubmissionType {
  TEXT
  LINK
  FILE
  SCREENSHOT
}

enum EligibilityTier {
  NEW
  VERIFIED
  TRUSTED
  HIGH_TRUST
  RESTRICTED
}

enum JobRole {
  DEVELOPER
  DESIGNER
  WRITER
  MARKETING
  COMMUNITY
  RESEARCH
  VIDEO
  OTHER
}

model Contributor {
  id                      Int             @id @default(autoincrement())
  telegramUserId          BigInt          @unique
  telegramUsername        String?
  displayName             String?

  // Registration / onboarding. /onboard collects jobRole, desiredIncome, and
  // skillTags via a button+text wizard (src/bot/commands/onboard.js).
  // twitterHandle/twitterScore are no longer collected by that flow - kept
  // here (and in src/candidateEvaluation.js / src/twitterClient.js) as
  // unused-but-functional infrastructure in case Twitter-based evaluation
  // is reintroduced later; computeTwitterScore already returns null when
  // twitterHandle is unset, so this degrades gracefully.
  twitterHandle           String?
  isRegistered            Boolean         @default(false)
  eligibilityTier         EligibilityTier @default(NEW)
  jobRole                 JobRole?
  desiredIncome           String?
  twitterScore            Float?
  telegramScore           Float?
  socialTrustScore        Float?
  riskFlags               String[]        @default([])
  skillTags               String[]        @default([])
  preferredCategories     String[]        @default([])
  lastEvaluatedAt         DateTime?

  // Reputation / performance
  completedTaskCount      Int             @default(0)
  rejectedSubmissionCount Int             @default(0)
  trustStatus             String          @default("unverified")

  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  applications Application[]

  @@map("contributors")
}

model Signal {
  id                  Int      @id @default(autoincrement())
  source              String
  summary              String
  rawText              String?
  status               String   @default("NEW")
  createdByTelegramId  BigInt
  createdAt            DateTime @default(now())

  // For DB-backed per-room rate limiting (src/signalDetection.js) - null for
  // signals evaluated outside a tracked room.
  roomId              Int?
  room                Room?    @relation(fields: [roomId], references: [id])

  task Task?

  @@map("signals")
}

model Task {
  id                 Int        @id @default(autoincrement())
  title               String
  description          String
  category             String?
  requiredSkills       String[]   @default([])
  reward               String?
  deadline             DateTime?
  requiredOutput       String?
  status               TaskStatus @default(DRAFT)
  // How many applications can be ASSIGNED at once. Most tasks are 1
  // (single contributor); crowdsourced/parallel tasks can set it higher.
  maxAssignees         Int        @default(1)
  createdByTelegramId  BigInt

  signalId             Int?       @unique
  signal               Signal?    @relation(fields: [signalId], references: [id])

  // The Telegram group this task belongs to, for room-scoped admin
  // permissions. Null means it was created via DM by a global admin.
  roomId               Int?
  room                 Room?      @relation(fields: [roomId], references: [id])

  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  applications Application[]
  history      TaskHistory[]

  @@map("tasks")
}

// One contributor's candidacy for one task. A contributor may hold multiple
// Application rows against the same task over time (e.g. re-applying after
// being Declined or Unassigned), but only one ACTIVE one (Applied/Assigned)
// at a time - enforced at the command level, not the schema level.
model Application {
  id             Int               @id @default(autoincrement())
  taskId         Int
  task           Task              @relation(fields: [taskId], references: [id])
  contributorId  Int
  contributor    Contributor       @relation(fields: [contributorId], references: [id])
  status         ApplicationStatus @default(APPLIED)

  // Match score computed at apply time (src/matching.js), shown to admins
  // via /applicants to help decide who to /assign.
  matchScore     Float?
  unassignReason String?

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  submissions Submission[]
  history     ApplicationHistory[]

  @@map("applications")
}

// Each resubmission is a new row (version), not an overwrite - so revision
// history is fully auditable.
model Submission {
  id                     Int              @id @default(autoincrement())
  applicationId          Int
  application            Application      @relation(fields: [applicationId], references: [id])
  version                Int
  status                 SubmissionStatus @default(SUBMITTED)

  submissionType         SubmissionType?
  submissionContent      String?
  submissionFileId       String?
  sourceUrl               String?
  submissionFileMetadata   Json?
  reviewerNote             String?
  aiReviewNote             String?

  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  history SubmissionHistory[]

  @@unique([applicationId, version])
  @@map("submissions")
}

// A Telegram group the bot operates in. Auto-created when the bot is
// invited (see signalChatAdmin.js). Owns its own admin roster (RoomAdmin)
// so multiple groups can be managed independently of each other and of the
// global ADMIN_TELEGRAM_IDS superadmins.
model Room {
  id              Int      @id @default(autoincrement())
  chatId          BigInt   @unique
  chatTitle       String?
  signalsEnabled  Boolean  @default(false)
  // Room-scoped "AI mode" (src/bot/commands/aiToggle.js): when on, plain
  // messages and commands in this room are routed to the AI agent
  // (src/ai/agent.js) instead of the classic command handlers.
  aiEnabled       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  admins  RoomAdmin[]
  tasks   Task[]
  signals Signal[]

  @@map("rooms")
}

model RoomAdmin {
  id             Int      @id @default(autoincrement())
  roomId         Int
  room           Room     @relation(fields: [roomId], references: [id])
  telegramUserId BigInt
  addedAt        DateTime @default(now())

  @@unique([roomId, telegramUserId])
  @@map("room_admins")
}

model TaskHistory {
  id              Int         @id @default(autoincrement())
  taskId          Int
  task            Task        @relation(fields: [taskId], references: [id])
  fromStatus      TaskStatus?
  toStatus        TaskStatus
  actorTelegramId BigInt
  note            String?
  createdAt       DateTime    @default(now())

  @@map("task_history")
}

model ApplicationHistory {
  id              Int                @id @default(autoincrement())
  applicationId   Int
  application     Application        @relation(fields: [applicationId], references: [id])
  fromStatus      ApplicationStatus?
  toStatus        ApplicationStatus
  actorTelegramId BigInt
  note            String?
  createdAt       DateTime           @default(now())

  @@map("application_history")
}

model SubmissionHistory {
  id              Int               @id @default(autoincrement())
  submissionId    Int
  submission      Submission        @relation(fields: [submissionId], references: [id])
  fromStatus      SubmissionStatus?
  toStatus        SubmissionStatus
  actorTelegramId BigInt
  note            String?
  createdAt       DateTime          @default(now())

  @@map("submission_history")
}
