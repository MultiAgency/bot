generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TaskStatus {
  SIGNAL
  DRAFT
  APPROVED
  ROUTED
  CLAIMED
  SUBMITTED
  REVISION_REQUESTED
  REJECTED
  REVIEWED
  AMPLIFIED
  COMPLETED
}

enum SubmissionType {
  TEXT
  LINK
  FILE
  SCREENSHOT
}

enum EligibilityTier {
  NEW
  VERIFIED
  TRUSTED
  HIGH_TRUST
  RESTRICTED
}

model Contributor {
  id                      Int             @id @default(autoincrement())
  telegramUserId          BigInt          @unique
  telegramUsername        String?
  displayName             String?

  // Registration / onboarding (candidate evaluation via Twitter + Telegram)
  twitterHandle           String?
  isRegistered            Boolean         @default(false)
  eligibilityTier         EligibilityTier @default(NEW)
  twitterScore            Float?
  telegramScore           Float?
  socialTrustScore        Float?
  riskFlags               String[]        @default([])
  skillTags               String[]        @default([])
  preferredCategories     String[]        @default([])
  lastEvaluatedAt         DateTime?

  // Reputation / performance
  claimedTaskCount        Int             @default(0)
  completedTaskCount      Int             @default(0)
  rejectedSubmissionCount Int             @default(0)
  trustStatus             String          @default("unverified")

  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  claimedTasks Task[] @relation("ClaimedTasks")
  routedTasks  Task[] @relation("RoutedTasks")

  @@map("contributors")
}

model Signal {
  id                  Int      @id @default(autoincrement())
  source              String
  summary              String
  rawText              String?
  status               String   @default("NEW")
  createdByTelegramId  BigInt
  createdAt            DateTime @default(now())

  task Task?

  @@map("signals")
}

model Task {
  id                     Int             @id @default(autoincrement())
  title                   String
  description             String
  category                String?
  requiredSkills          String[]        @default([])
  reward                  String?
  deadline                DateTime?
  requiredOutput          String?
  status                  TaskStatus      @default(DRAFT)
  createdByTelegramId     BigInt

  signalId                Int?            @unique
  signal                  Signal?         @relation(fields: [signalId], references: [id])

  // Route step: system-suggested / assigned contributor before claim
  routedContributorId     Int?
  routedContributor       Contributor?    @relation("RoutedTasks", fields: [routedContributorId], references: [id])
  matchScore               Float?

  assignedContributorId   Int?
  assignedContributor     Contributor?    @relation("ClaimedTasks", fields: [assignedContributorId], references: [id])

  submissionType          SubmissionType?
  submissionContent       String?
  submissionFileId        String?
  sourceUrl                String?
  submissionFileMetadata   Json?
  reviewerNote             String?

  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  history TaskHistory[]

  @@map("tasks")
}

model TaskHistory {
  id              Int        @id @default(autoincrement())
  taskId          Int
  task            Task       @relation(fields: [taskId], references: [id])
  fromStatus      TaskStatus?
  toStatus        TaskStatus
  actorTelegramId BigInt
  note            String?
  createdAt       DateTime   @default(now())

  @@map("task_history")
}
