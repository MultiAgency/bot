# Telegram bot token from @BotFather
BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to create tasks / review submissions
ADMIN_TELEGRAM_IDS=

# Postgres connection string (Neon recommended: https://neon.tech)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Anthropic API key for AI-assist features (task drafting, submission summaries)
ANTHROPIC_API_KEY=

# Optional: raises Jina Reader's URL-to-file rate limit from 20 to 500 req/min.
# Leave blank to use the free, keyless tier.
JINA_API_KEY=

# Optional: enables real Twitter/X candidate scoring once implemented.
# Leave blank to keep twitterScore as an unscored stub (see src/candidateEvaluation.js).
TWITTER_BEARER_TOKEN=
