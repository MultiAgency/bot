# Telegram bot token from @BotFather
BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to create tasks / review submissions
ADMIN_TELEGRAM_IDS=

# Postgres connection string (Neon recommended: https://neon.tech)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Anthropic API key for AI-assist features (task drafting, submission summaries)
ANTHROPIC_API_KEY=

# Optional: raises Jina Reader's URL-to-file rate limit from 20 to 500 req/min.
# Leave blank to use the free, keyless tier.
JINA_API_KEY=

# Optional: enables real Twitter/X candidate scoring once implemented.
# Leave blank to keep twitterScore as an unscored stub (see src/candidateEvaluation.js).
TWITTER_BEARER_TOKEN=

# Signal detection (auto-drafting tasks from group chat) is opt-in per chat,
# enabled at runtime via /enablesignals inside the group - no env var needed.
# Still requires disabling Telegram's bot Privacy Mode via @BotFather first
# (see DEPLOY.md), or the bot never receives non-command messages at all.

# Optional: minimum Claude-assigned score (0-10) before an auto-detected
# signal becomes a draft task. Defaults to 6.
SIGNAL_SCORE_THRESHOLD=6

# Optional: max signal evaluations per watched chat per hour, to cap API
# spend on very active groups. Defaults to 20.
SIGNAL_MAX_PER_HOUR=20

# Optional: minutes a routed task is reserved for the suggested contributor
# before anyone else can /claim it. Defaults to 30.
ROUTE_LOCK_MINUTES=30

# Optional: how often (minutes) the scheduler checks for expired route locks
# and reroutes/opens unclaimed tasks. Defaults to 10.
ROUTE_CHECK_INTERVAL_MINUTES=10

# Optional: max number of automatic reroutes before a task is opened to any
# registered contributor instead of trying another suggestion. Defaults to 3.
ROUTE_MAX_REROUTES=3
